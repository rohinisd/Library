# Copy to .env and fill in. Never commit .env.

# Vercel deployment (required for Cursor/CI to deploy without prompts)
VERCEL_TOKEN=your_vercel_api_token_here

# GitHub – repo creation and API (see GITHUB_SETUP.md)
GITHUB_TOKEN=your_github_personal_access_token_here

# Neon (Postgres) – required for DB creation and CLI (see NEON_SETUP.md)
NEON_API_KEY=your_neon_api_key_here
# After first DB/project: connection string for running SQL and app runtime
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
# Optional: set if you have multiple projects
# NEON_PROJECT_ID=

# Render – backend/API deploy from CLI (see RENDER_SETUP.md)
RENDER_API_KEY=your_render_api_key_here
RENDER_OWNER_ID=tea-xxxx
# Library backend (library-api). Set by render-setup-backend.ps1; render-deploy.ps1 uses this for Library.
RENDER_BACKEND_SERVICE_ID=srv-xxxx
# Optional: other service (e.g. SFMS). render-deploy.ps1 prefers RENDER_BACKEND_SERVICE_ID.
# RENDER_SERVICE_ID=srv-xxxx

# Backend (FastAPI on Render) – same JWT_SECRET on Vercel and Render
JWT_SECRET=your_shared_secret_min_32_chars

# Google OAuth (optional). See OAUTH_SETUP.md. Then run scripts/oauth-setup-render.ps1
# In Google Console, Authorized JavaScript origins = your real Vercel URL(s) + http://localhost:3000 — NOT console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Exact URL users open in the browser (often team URL like https://app-name-team.vercel.app)
FRONTEND_URL=https://your-app.vercel.app

# Optional: set if the project is not linked via vercel link
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=

# Fly.io – for deploy/launch from CLI (see FLY_SETUP.md)
# FLY_API_TOKEN=your_fly_api_token_here
# FLY_APP_NAME=my-app

# Optional: Vercel team (for vercel-create-project.ps1 when using a team)
# VERCEL_TEAM_ID=
